loadModel("BouncingBall");
time := 0.2;
baseClock := interval(0.1);
slowClock := subSample(baseClock, 2);
fastClock := superSample(baseClock, 2);
shiftedClock := shiftSample(baseClock, 1);
flag := sample(0.0, baseClock);
if flag then
  setStopTime(0.2);
else
  setStopTime(0.1);
end if;
simulate(model="BouncingBall", stopTime=0.2, stepSize=0.01, method="rk45", resultFile="omc_sync_signal.csv");
quit();
