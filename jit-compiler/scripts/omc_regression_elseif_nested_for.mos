loadModel("BouncingBall");
score := 0;
for i in 1:2 loop
  for j in 1:3 loop
    score := score + 1;
  end for;
end for;
if score < 5 then
  setStopTime(0.1);
elseif score == 6 then
  setStopTime(0.25);
else
  setStopTime(0.15);
end if;
simulate(model="BouncingBall", stopTime=0.25, stepSize=0.01, method="rk45", resultFile="omc_elseif_nested.csv");
quit();
