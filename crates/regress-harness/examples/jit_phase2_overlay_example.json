{
  "version": 1,
  "includes": [
    "testlib_from_run_regression.json",
    "mos_from_run_mos_regression.json"
  ],
  "defaults": {
    "repo_root": ".",
    "working_dir": "jit-compiler",
    "cargo_run_models": true,
    "cargo_target_dir_primary": "target_regression",
    "regression_data_root": "build/regression_data_jit_phase2"
  },
  "execution": {
    "workers": 4,
    "fail_fast": false
  },
  "incremental": {
    "baseline_path": null,
    "strategy": "none"
  },
  "tiers": {
    "phase2": {
      "include_tags": ["jit-phase2"]
    },
    "phase2_perf": {
      "include_tags": ["perf-smoke"]
    },
    "phase2_sync": {
      "include_tags": ["sync-det", "sync-trace-assert"]
    },
    "phase2_sync_det": {
      "include_tags": ["sync-det"]
    },
    "phase2_sync_trace_assert": {
      "include_tags": ["sync-trace-assert"]
    },
    "phase2_gate": {
      "include_tags": ["coverage", "fmi"]
    },
    "phase2_coverage": {
      "include_tags": ["coverage"]
    },
    "phase2_fmi": {
      "include_tags": ["fmi"]
    },
    "phase2_dir": {
      "include_tags": ["dir"]
    },
    "phase2_event": {
      "include_tags": ["event-scan"]
    },
    "phase2_summary": {
      "include_tags": ["sparse-dense-summary"]
    }
  },
  "cases": [
    {
      "id": "phase2_perf_smoke_clocked_partition_test",
      "kind": "custom_command",
      "target": "PERF-SMOKE/TestLib/ClockedPartitionTest",
      "program": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "../crates/regress-harness/scripts/Invoke-JitPerfSmoke.ps1",
        "-RepoRoot",
        "..",
        "-CargoTargetDir",
        "target_regression",
        "-Model",
        "TestLib/ClockedPartitionTest",
        "-TEnd",
        "2.0",
        "-Dt",
        "0.01",
        "-OutputInterval",
        "0.01",
        "-CompileMsMax",
        "60000",
        "-SimMsMax",
        "60000",
        "-EventIterMax",
        "5000",
        "-ClockDispatchMax",
        "5000"
      ],
      "tags": ["jit-phase2", "perf-smoke"],
      "expect": { "kind": "exit_zero" },
      "timeout_ms": 900000
    },
    {
