    { "id": "q_neg_bad_connect",         "kind": "model", "target": "TestLib/negative/BadConnect",     "tags": ["quick", "negative"], "expect": { "kind": "non_zero" } },
    { "id": "q_neg_unknown_type",        "kind": "model", "target": "TestLib/negative/UnknownTypeError","tags": ["quick", "negative"], "expect": { "kind": "non_zero" } },

    { "id": "q_stress_broad",            "kind": "model", "target": "ModelicaTest/JitStress/MslBroadCoverage", "tags": ["quick", "stress"], "expect": { "kind": "exit_zero" } }
