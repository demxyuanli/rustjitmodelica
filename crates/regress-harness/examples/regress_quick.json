    { "id": "q_misc_multi_top",          "kind": "model", "target": "TestLib/MultiTopCombined",    "tags": ["quick"], "expect": { "kind": "exit_zero" } },
    { "id": "q_misc_math_builtins",      "kind": "model", "target": "TestLib/MathBuiltins",        "tags": ["quick"], "expect": { "kind": "exit_zero" } },
    { "id": "q_misc_nested_der",         "kind": "model", "target": "TestLib/NestedDerTest",       "tags": ["quick"], "expect": { "kind": "exit_zero" } },
