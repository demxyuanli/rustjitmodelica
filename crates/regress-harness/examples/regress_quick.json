{
  "version": 1,
  "includes": ["regress_smoke_v2.json"],
  "defaults": {
    "repo_root": ".",
    "rustmodlica_exe": "auto",
    "working_dir": "jit-compiler",
    "solver": "rk4",
    "t_end": 10.0,
    "dt": 0.01
  },
  "execution": {
    "workers": 4,
    "fail_fast": false
  },
  "incremental": {
    "strategy": "none"
  },
  "tiers": {
    "smoke": {
      "include_tags": ["smoke"]
    },
    "quick": {
      "extends": "smoke",
      "include_tags": ["smoke", "quick"]
    }
  },
  "cases": [
    { "id": "q_lang_while",              "kind": "model", "target": "TestLib/WhileTest",           "tags": ["quick"], "expect": { "kind": "exit_zero" } },
    { "id": "q_lang_alg",                "kind": "model", "target": "TestLib/AlgTest",             "tags": ["quick"], "expect": { "kind": "exit_zero" } },
    { "id": "q_lang_init_alg",           "kind": "model", "target": "TestLib/InitAlg",            "tags": ["quick"], "expect": { "kind": "exit_zero" } },

    { "id": "q_evt_reinit",              "kind": "model", "target": "TestLib/ReinitTest",          "tags": ["quick"], "expect": { "kind": "exit_zero" } },
